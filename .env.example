## Supabase (cloud sync)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_SYNC_ENABLED=true

# Optional: used in CI to show a build id in the Profit header
# VITE_APP_BUILD=

# Single-owner mode: only this email can modify trades; everyone else is read-only (RLS + UI).
# Example: you@domain.com
VITE_ADMIN_EMAIL=

# Optional: prepended before the encoded CoinGecko URL (browser cannot call CoinGecko directly from GH Pages).
# The app tries CodeTabs + other public proxies by default; set this to your own worker if needed.
# Example style (must end so the encoded URL appends correctly): https://api.allorigins.win/raw?url=
# VITE_CORS_PROXY_BASE=

# CoinGecko Demo API key (coingecko.com → API dashboard). Appends x_cg_demo_api_key=… to each request.
# Reduces “rate limit” errors vs anonymous free tier; still visible in the built JS bundle.
# VITE_COINGECKO_API_KEY=

# Revolut Business API — USD prices via Supabase Edge Function (recommended: token never in the browser).
# 1) Deploy `supabase/functions/revolut-prices` and set secret REVOLUT_ACCESS_TOKEN on the function.
# 2) Set true below. Requires VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY (same as sync).
# Coin symbol search still uses CoinGecko unless you replace that flow separately.
# VITE_USE_REVOLUT_EDGE_PRICES=false

# Supabase Auth setup (dashboard):
# - Enable Email provider + Google/GitHub OAuth apps as needed
# - URL Configuration → Site URL: your deployed origin (e.g. https://mwtre.github.io)
# - Redirect URLs must include:
#   - http://localhost:5173/BLmw3/
#   - https://mwtre.github.io/BLmw3/
