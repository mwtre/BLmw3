## Supabase (cloud sync)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_SYNC_ENABLED=true

# Optional: used in CI to show a build id in the Profit header
# VITE_APP_BUILD=

# Owner identity for Supabase sync push (must match signed-in email). RLS limits server writes to this user.
# Example: you@domain.com
VITE_ADMIN_EMAIL=

# Optional: when true with VITE_ADMIN_EMAIL set, non-owner signed-in users get read-only Profit UI (Add trade / import disabled).
# Default is false so everyone can keep a local journal; server still only accepts writes from the owner.
# VITE_LEDGER_UI_READONLY=true

# CoinPaprika — spot prices + search (browser-safe CORS on free tier api.coinpaprika.com).
# Optional Pro key (docs.coinpaprika.com); switches default base to api-pro.coinpaprika.com when set.
# VITE_COINPAPRICA_API_KEY=
# Override API host if needed:
# VITE_COINPAPRICA_BASE=https://api.coinpaprika.com/v1

# Supabase Auth setup (dashboard):
# - Enable Email provider + Google/GitHub OAuth apps as needed
# - URL Configuration → Site URL: your deployed origin (e.g. https://mwtre.github.io)
# - Redirect URLs must include:
#   - http://localhost:5173/BLmw3/
#   - https://mwtre.github.io/BLmw3/
