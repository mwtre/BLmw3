## Supabase (optional cloud sync)
# Create a Supabase project and set these in GitHub Actions secrets for Pages builds.
# For local dev, you can copy this file to `.env.local`.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Enable/disable cloud sync in the app (defaults to off if keys are missing).
VITE_SUPABASE_SYNC_ENABLED=false

